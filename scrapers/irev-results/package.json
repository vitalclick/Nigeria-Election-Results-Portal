{
  "name": "@openballot/irev-results-scraper",
  "version": "0.1.0",
  "private": true,
  "description": "Scrape 2023 INEC IReV results, mirror EC8A images, and ingest into OpenBallot.",
  "main": "scrape.js",
  "scripts": {
    "scrape": "node scrape.js",
